{
    "identifier": "projects",
    "name": "Projects",
    "type": "module",
    "version": "1.0.0",
    "description": "Project management module with CRUD operations, team-scoping, and permission-based access.",
    "provider": "Modules\\Projects\\ProjectServiceProvider",
    "namespace": "Modules\\Projects",
    "author": "OneSubnet",
    "license": "MIT",
    "lastarterVersion": "^1.0",
    "permissions": [
        "project.view",
        "project.create",
        "project.update",
        "project.delete"
    ],
    "navigation": {
        "app": [
            {
                "title": "Projects",
                "icon": "FolderKanban",
                "route": "projects.index",
                "permission": "project.view",
                "order": 10
            }
        ]
    },
    "settings": [
        {
            "key": "projects.default_visibility",
            "label": "Default Visibility",
            "type": "select",
            "options": ["private", "public"],
            "default": "private"
        }
    ]
}
