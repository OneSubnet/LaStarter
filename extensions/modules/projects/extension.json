{
    "identifier": "projects",
    "name": "Projects",
    "type": "module",
    "version": "1.0.0",
    "description": "Project management module with CRUD operations, team-scoping, and permission-based access.",
    "provider": "Modules\\Projects\\ProjectServiceProvider",
    "namespace": "Modules\\Projects",
    "author": "OneSubnet",
    "license": "MIT",
    "minimum_core_version": "^1.0",
    "dependencies": [],
    "provides": ["project-management"],
    "permissions": [
        "project.view",
        "project.create",
        "project.update",
        "project.delete"
    ],
    "navigation": {
        "app": [
            {
                "title": "Projects",
                "icon": "FolderKanban",
                "route": "projects.index",
                "permission": "project.view",
                "order": 10
            }
        ]
    },
    "settings": [
        {
            "key": "projects.default_visibility",
            "label": "Default Visibility",
            "type": "select",
            "options": ["private", "public"],
            "default": "private"
        }
    ],
    "widgets": [
        {
            "identifier": "projects-summary",
            "label": "Projects Summary",
            "type": "stat",
            "size": { "w": 3, "h": 2 },
            "permission": "project.view"
        }
    ],
    "metrics": [
        { "key": "total_projects", "label": "Total Projects", "type": "number" },
        { "key": "active_projects", "label": "Active Projects", "type": "number" }
    ]
}
