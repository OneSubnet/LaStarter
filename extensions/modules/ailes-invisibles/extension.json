{
    "identifier": "ailes-invisibles",
    "name": "Ailes Invisibles",
    "type": "module",
    "version": "1.0.0",
    "description": "Portail client complet avec gestion CRM, facturation, documents, signature electronique et messagerie chiffree",
    "author": "LaStarter",
    "license": "proprietary",
    "provider": "Modules\\AilesInvisibles\\AilesInvisiblesServiceProvider",
    "namespace": "Modules\\AilesInvisibles",
    "lastarterVersion": ">=1.0.0",
    "keywords": ["crm", "invoicing", "portal", "documents", "signatures", "messaging", "encryption"],
    "permissions": [
        "ai.client.view",
        "ai.client.create",
        "ai.client.update",
        "ai.client.delete",
        "ai.client.invite",
        "ai.category.view",
        "ai.category.create",
        "ai.category.update",
        "ai.category.delete",
        "ai.product.view",
        "ai.product.create",
        "ai.product.update",
        "ai.product.delete",
        "ai.event.view",
        "ai.event.create",
        "ai.event.update",
        "ai.event.delete",
        "ai.quote.view",
        "ai.quote.create",
        "ai.quote.update",
        "ai.quote.delete",
        "ai.quote.send",
        "ai.quote.accept",
        "ai.quote.convert",
        "ai.invoice.view",
        "ai.invoice.create",
        "ai.invoice.update",
        "ai.invoice.delete",
        "ai.invoice.send",
        "ai.invoice.record-payment",
        "ai.invoice.cancel",
        "ai.accounting.view",
        "ai.accounting.reports",
        "ai.document.view",
        "ai.document.upload",
        "ai.document.delete",
        "ai.document.assign",
        "ai.document.download",
        "ai.conversation.view",
        "ai.conversation.create",
        "ai.conversation.send"
    ],
    "navigation": {
        "app": [
            {
                "title": "Ailes Invisibles",
                "icon": "Feather",
                "children": [
                    { "title": "Clients", "icon": "Users", "route": "ai.clients.index", "permission": "ai.client.view", "group": "crm", "order": 20 },
                    { "title": "Categories", "icon": "FolderOpen", "route": "ai.categories.index", "permission": "ai.product.view", "group": "crm", "order": 20 },
                    { "title": "Catalogue", "icon": "Package", "route": "ai.products.index", "permission": "ai.product.view", "group": "crm", "order": 21 },
                    { "title": "Evenements", "icon": "Calendar", "route": "ai.events.index", "permission": "ai.event.view", "group": "operations", "order": 30 },
                    { "title": "Devis", "icon": "FileText", "route": "ai.quotes.index", "permission": "ai.quote.view", "group": "operations", "order": 31 },
                    { "title": "Factures", "icon": "Receipt", "route": "ai.invoices.index", "permission": "ai.invoice.view", "group": "operations", "order": 32 },
                    { "title": "Comptabilite", "icon": "Calculator", "route": "ai.accounting.dashboard", "permission": "ai.accounting.view", "group": "finance", "order": 40 },
                    { "title": "Documents", "icon": "FolderOpen", "route": "ai.documents.index", "permission": "ai.document.view", "group": "communication", "order": 50 },
                    { "title": "Messagerie", "icon": "MessageCircle", "route": "ai.conversations.inbox", "permission": "ai.conversation.view", "group": "communication", "order": 51 }
                ]
            }
        ]
    }
}
